<script>
// ── HERO PHOTO SLIDESHOW ──
const slides = document.querySelectorAll('.slide');
const dots   = document.querySelectorAll('.sdot');
const sceneNames = ['High-Bay Warehouse','Logistics & Transport','Forklift Operations','Cargo Transport'];
let curSlide = 0, slideTimer;

function goSlide(n){
  slides[curSlide].classList.remove('active');
  dots[curSlide].classList.remove('on');
  curSlide = n;
  slides[curSlide].classList.add('active');
  dots[curSlide].classList.add('on');
  document.getElementById('sceneLabel').textContent = sceneNames[curSlide];
  clearInterval(slideTimer);
  slideTimer = setInterval(nextSlide, 5500);
}
function nextSlide(){ goSlide((curSlide+1) % slides.length); }
slideTimer = setInterval(nextSlide, 5500);

// Nav scroll
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>{
  if(window.scrollY>80){nav.classList.remove('top');nav.classList.add('solid');}
  else{nav.classList.remove('solid');nav.classList.add('top');}
});

// Scroll reveal
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');});
},{threshold:.1});
document.querySelectorAll('.fu,.fl,.fr').forEach(el=>obs.observe(el));

// FAQ
function tFaq(btn){
  const item=btn.closest('.fi'),was=item.classList.contains('open');
  document.querySelectorAll('.fi').forEach(i=>i.classList.remove('open'));
  if(!was)item.classList.add('open');
}

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const t=document.querySelector(a.getAttribute('href'));
    if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
  });
});

// Google Form fallback
setTimeout(()=>{
  try{
    const f=document.getElementById('gform');
    if(!f.contentDocument||!f.contentDocument.body||f.contentDocument.body.innerHTML.trim()==='')
      document.getElementById('gfb').style.display='block';
  }catch(e){}
},9000);
</script>
