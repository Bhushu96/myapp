<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>SAP Warehouse Management Consultant</title>
<meta name="description" content="Independent SAP WM & EWM Consultant for European businesses. Implementations, S/4HANA migrations, process optimisation."/>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --white:#ffffff;--off:#f7f6f4;--light:#eeecea;--border:#dbd8d3;
  --muted:#8c8580;--body:#3d3a36;--ink:#1a1917;
  --blue:#1d4e89;--blue2:#2563aa;--blue-light:#e8eff8;
  --green:#166534;--green-bg:#f0faf3;
  --shadow:0 4px 16px rgba(0,0,0,.09);--shadow-lg:0 12px 40px rgba(0,0,0,.12);
}
html{scroll-behavior:smooth}
body{font-family:"Source Sans 3",sans-serif;background:var(--white);color:var(--body);line-height:1.65;overflow-x:hidden}
.container{max-width:1120px;margin:0 auto;padding:0 40px}
.eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:.72rem;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--blue);margin-bottom:14px}
.eyebrow::before{content:"";width:20px;height:2px;background:var(--blue);flex-shrink:0}
.section-h{font-family:"Libre Baskerville",serif;font-size:clamp(1.8rem,3.2vw,2.6rem);color:var(--ink);line-height:1.2;letter-spacing:-.4px;margin-bottom:16px}
.section-sub{font-size:1.02rem;color:var(--muted);line-height:1.75;font-weight:300;max-width:560px}
.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:4px;font-weight:600;font-size:.92rem;cursor:pointer;transition:all .22s;border:none;letter-spacing:.3px;font-family:"Source Sans 3",sans-serif;text-decoration:none}
.btn-p{background:var(--blue);color:#fff;box-shadow:var(--shadow)}
.btn-p:hover{background:var(--blue2);transform:translateY(-1px);box-shadow:var(--shadow-lg)}
.btn-o{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5)}
.btn-o:hover{background:rgba(255,255,255,.12);border-color:#fff}

/* NAV */
nav{position:fixed;top:0;inset-x:0;z-index:100;transition:all .35s}
nav.top{background:transparent;padding:22px 0}
nav.solid{background:var(--white);padding:14px 0;box-shadow:var(--shadow)}
.nav-in{max-width:1120px;margin:0 auto;padding:0 40px;display:flex;align-items:center;justify-content:space-between}
.nlogo{font-family:"Libre Baskerville",serif;font-size:1.05rem;font-weight:700;text-decoration:none;transition:color .3s}
nav.top .nlogo{color:#fff}
nav.solid .nlogo{color:var(--ink)}
.nlogo span{color:var(--blue)}
nav.top .nlogo span{color:#93c5f5}
.nlinks{display:flex;align-items:center;gap:4px;list-style:none}
.nlinks a{font-size:.86rem;font-weight:500;padding:7px 14px;border-radius:3px;transition:all .2s;text-decoration:none}
nav.top .nlinks a{color:rgba(255,255,255,.85)}
nav.top .nlinks a:hover{color:#fff;background:rgba(255,255,255,.1)}
nav.solid .nlinks a{color:var(--muted)}
nav.solid .nlinks a:hover{color:var(--ink);background:var(--off)}
.ncta{font-weight:600 !important}
nav.top .ncta{background:rgba(255,255,255,.15) !important;border:1.5px solid rgba(255,255,255,.35) !important;border-radius:4px !important;color:#fff !important}
nav.solid .ncta{background:var(--blue) !important;color:#fff !important;border-radius:4px !important}
nav.solid .ncta:hover{background:var(--blue2) !important}

/* HERO */

/* ══ HERO — PHOTO SLIDESHOW ══
   Uses CSS background-image — photos display on any hosted site (GitHub Pages etc).
   Falls back to a beautiful gradient scene locally.
   IMPORTANT: To see real photos, upload to GitHub Pages — photos load automatically.
*/
.hero{
  position:relative;min-height:100vh;display:flex;align-items:center;
  padding:130px 0 90px;overflow:hidden;
}

/* Each slide is a full-bleed background panel */
.slide{
  position:absolute;inset:0;
  background-size:cover;background-position:center;background-repeat:no-repeat;
  opacity:0;transition:opacity 2s ease-in-out;
  z-index:0;
}
.slide.active{opacity:1}

/* Photo URLs — Pexels warehouse & logistics (load when hosted) */
.slide-1{background-image:
  linear-gradient(rgba(8,18,38,.55),rgba(8,18,38,.55)),
  url("https://images.pexels.com/photos/1267338/pexels-photo-1267338.jpeg?auto=compress&cs=tinysrgb&w=1600");}
.slide-2{background-image:
  linear-gradient(rgba(8,18,38,.5),rgba(8,18,38,.5)),
  url("https://images.pexels.com/photos/2199293/pexels-photo-2199293.jpeg?auto=compress&cs=tinysrgb&w=1600");}
.slide-3{background-image:
  linear-gradient(rgba(8,18,38,.5),rgba(8,18,38,.5)),
  url("https://images.pexels.com/photos/4481259/pexels-photo-4481259.jpeg?auto=compress&cs=tinysrgb&w=1600");}
.slide-4{background-image:
  linear-gradient(rgba(8,18,38,.5),rgba(8,18,38,.5)),
  url("https://images.pexels.com/photos/1118448/pexels-photo-1118448.jpeg?auto=compress&cs=tinysrgb&w=1600");}

/* CSS fallback — beautiful gradient scene when photos can't load (local) */
.hero-fallback{
  position:absolute;inset:0;z-index:0;overflow:hidden;
  background:linear-gradient(160deg,#0a1628 0%,#12284a 40%,#0f2040 70%,#080f1e 100%);
}
/* Sky stars */
.hero-fallback::before{
  content:"";position:absolute;inset:0;
  background-image:
    radial-gradient(1px 1px at 10% 8%,rgba(255,255,255,.7) 0%,transparent 100%),
    radial-gradient(1px 1px at 22% 15%,rgba(255,255,255,.5) 0%,transparent 100%),
    radial-gradient(1px 1px at 35% 5%,rgba(255,255,255,.8) 0%,transparent 100%),
    radial-gradient(1.5px 1.5px at 50% 10%,rgba(255,255,255,.6) 0%,transparent 100%),
    radial-gradient(1px 1px at 65% 7%,rgba(255,255,255,.7) 0%,transparent 100%),
    radial-gradient(1px 1px at 78% 12%,rgba(255,255,255,.5) 0%,transparent 100%),
    radial-gradient(1.2px 1.2px at 88% 6%,rgba(255,255,255,.9) 0%,transparent 100%),
    radial-gradient(1px 1px at 95% 18%,rgba(255,255,255,.6) 0%,transparent 100%),
    radial-gradient(1px 1px at 15% 22%,rgba(255,255,255,.4) 0%,transparent 100%),
    radial-gradient(1px 1px at 42% 20%,rgba(255,255,255,.5) 0%,transparent 100%),
    radial-gradient(1px 1px at 70% 25%,rgba(255,255,255,.4) 0%,transparent 100%);
}
/* Warehouse glow on right side */
.hero-fallback::after{
  content:"";position:absolute;right:-5%;top:10%;width:70%;height:80%;
  background:
    radial-gradient(ellipse 60% 40% at 80% 45%,rgba(29,78,137,.18) 0%,transparent 70%),
    radial-gradient(ellipse 40% 30% at 90% 70%,rgba(249,115,22,.08) 0%,transparent 60%);
}
/* Warehouse building — CSS only */
.wh-building{
  position:absolute;right:0;top:0;bottom:0;width:55%;
  background:linear-gradient(180deg,transparent 8%,rgba(14,30,58,.0) 8%);
  overflow:hidden;
}
.wh-building::before{
  content:"";position:absolute;
  left:10%;right:0;top:18%;bottom:25%;
  background:linear-gradient(180deg,#162d55 0%,#0f2040 100%);
  clip-path:polygon(0 8%,48% 0%,100% 8%,100% 100%,0 100%);
}
.wh-building::after{
  content:"";position:absolute;
  left:10%;right:0;bottom:25%;height:30%;
  background:rgba(11,20,38,.9);
}

/* Ground & road */
.hero-ground{
  position:absolute;bottom:0;left:0;right:0;height:28%;
  background:linear-gradient(180deg,#0c1a2e 0%,#080e1a 100%);
}
.hero-road{
  position:absolute;bottom:9%;left:0;right:0;height:11%;
  background:#0e1a28;
  border-top:2px solid rgba(255,255,255,.06);
  border-bottom:2px solid rgba(255,255,255,.06);
}
.hero-road::after{
  content:"";position:absolute;top:50%;left:0;right:0;height:2px;margin-top:-1px;
  background:repeating-linear-gradient(90deg,rgba(255,255,255,.25) 0px,rgba(255,255,255,.25) 36px,transparent 36px,transparent 60px);
}

/* Animated truck */
.hero-truck{
  position:absolute;bottom:calc(9% + 11%/2 - 28px);
  width:260px;height:56px;
  animation:truckRide 11s linear infinite;
  z-index:1;
}
@keyframes truckRide{
  0%{left:-280px;opacity:0}
  5%{opacity:1}
  92%{opacity:1}
  100%{left:calc(100% + 20px);opacity:0}
}
.truck-trailer{
  position:absolute;left:0;top:0;
  width:180px;height:46px;
  background:linear-gradient(180deg,#e8f0f8 0%,#c8d8e8 100%);
  border-radius:3px 3px 2px 2px;
}
.truck-trailer-roof{
  position:absolute;left:0;top:0;width:180px;height:8px;
  background:#1d4e89;border-radius:3px 3px 0 0;
}
.truck-trailer-text{
  position:absolute;left:0;top:12px;width:180px;
  font-size:7px;font-weight:bold;color:#1d4e89;
  text-align:center;letter-spacing:2px;font-family:Arial,sans-serif;
}
.truck-trailer-ribs{
  position:absolute;left:0;top:8px;width:180px;height:38px;
  background:repeating-linear-gradient(90deg,transparent 0px,transparent 35px,rgba(29,78,137,.15) 35px,rgba(29,78,137,.15) 36px);
}
.truck-cab{
  position:absolute;left:180px;top:4px;
  width:80px;height:42px;
  background:linear-gradient(135deg,#1d4e89,#2563aa);
  border-radius:3px 8px 3px 3px;
}
.truck-windshield{
  position:absolute;left:10px;top:6px;width:46px;height:22px;
  background:rgba(147,197,245,.5);border-radius:2px;
}
.truck-grill{
  position:absolute;left:68px;top:16px;width:12px;height:20px;
  background:#0a1628;border-radius:0 4px 4px 0;
}
.truck-headlight{
  position:absolute;left:69px;top:18px;width:9px;height:7px;
  background:#fef9c3;border-radius:0 2px 2px 0;
  box-shadow:0 0 12px 4px rgba(254,249,195,.5);
}
.truck-wheel{border-radius:50%;background:#0e1a28;border:3px solid #3a4a5a;position:absolute;bottom:-10px}
.tw1{width:24px;height:24px;left:20px}
.tw2{width:24px;height:24px;left:60px}
.tw3{width:24px;height:24px;left:140px}
.tw4{width:22px;height:22px;left:185px}
.tw5{width:22px;height:22px;left:216px}
.truck-exhaust{
  position:absolute;left:238px;top:-18px;width:6px;height:20px;
  background:#2a3a4a;border-radius:2px;
}
.exhaust-puff{
  position:absolute;left:234px;top:-30px;
  width:18px;height:18px;border-radius:50%;
  background:rgba(180,190,200,.25);
  animation:puff 1.5s ease-out infinite;
}
@keyframes puff{0%{transform:scale(0.3);opacity:.4}100%{transform:scale(2.5);opacity:0}}

/* Content */
.hero-c{position:relative;z-index:3;max-width:640px}

/* Text for dark background */
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:7px 18px;margin-bottom:28px;backdrop-filter:blur(8px)}
.bdot{width:8px;height:8px;background:#4ade80;border-radius:50%;animation:blink 2.5s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(74,222,128,.5)}50%{opacity:.8;box-shadow:0 0 0 7px rgba(74,222,128,0)}}
.btxt{font-size:.75rem;font-weight:700;color:rgba(255,255,255,.9);letter-spacing:1.5px;text-transform:uppercase}
.hero h1{font-family:"Libre Baskerville",serif;font-size:clamp(2rem,4.5vw,3.6rem);color:#fff;line-height:1.1;letter-spacing:-.5px;margin-bottom:18px}
.hero h1 em{font-style:italic;color:#93c5f5}
.hero-sub{font-size:1.02rem;color:rgba(255,255,255,.72);line-height:1.8;margin-bottom:36px;font-weight:300;max-width:520px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:52px}
.btn-o{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.4)}
.btn-o:hover{background:rgba(255,255,255,.12);border-color:#fff}
.hero-stats{display:flex;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:8px;overflow:hidden;max-width:480px;backdrop-filter:blur(12px)}
.hst{flex:1;padding:18px 20px;text-align:center;border-right:1px solid rgba(255,255,255,.1)}
.hst:last-child{border-right:none}
.hst-n{font-family:"Libre Baskerville",serif;font-size:1.9rem;color:#fff;font-weight:700;line-height:1;margin-bottom:4px}
.hst-l{font-size:.68rem;color:rgba(255,255,255,.5);letter-spacing:1px;text-transform:uppercase}
/* Bottom fade */
.hero-fade{position:absolute;bottom:0;left:0;right:0;height:120px;z-index:2;background:linear-gradient(to top,#fff,transparent)}
/* Slide dots */
.slide-dots{position:absolute;bottom:136px;right:40px;z-index:4;display:flex;gap:8px}
.sdot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.3);border:1px solid rgba(255,255,255,.4);cursor:pointer;transition:all .3s}
.sdot.on{background:#fff;width:22px;border-radius:4px}
/* Scene name */
.scene-label{position:absolute;bottom:136px;left:50%;transform:translateX(-50%);z-index:4;background:rgba(0,0,0,.4);border:1px solid rgba(255,255,255,.15);backdrop-filter:blur(10px);border-radius:20px;padding:5px 18px;font-size:.7rem;font-weight:600;color:rgba(255,255,255,.75);letter-spacing:1.5px;text-transform:uppercase;white-space:nowrap}
/* ABOUT */
.about{padding:108px 0;background:var(--white)}
.about-g{display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:center}
.about-img{position:relative}
.aimg{border-radius:6px;overflow:hidden;box-shadow:var(--shadow-lg);aspect-ratio:4/5;background:url('https://images.pexels.com/photos/1267338/pexels-photo-1267338.jpeg?auto=compress&cs=tinysrgb&w=800&fit=crop') center/cover}
.abadge{position:absolute;bottom:-24px;right:-24px;background:var(--blue);color:#fff;border-radius:8px;padding:22px 26px;box-shadow:var(--shadow-lg);text-align:center;min-width:136px}
.abn{font-family:"Libre Baskerville",serif;font-size:2.2rem;font-weight:700;line-height:1;margin-bottom:5px}
.abl{font-size:.7rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;opacity:.8}
.about-text p{font-size:.97rem;color:var(--muted);line-height:1.85;margin-bottom:16px;font-weight:300}
.skills-g{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin:28px 0}
.sk{display:flex;align-items:center;gap:8px;font-size:.86rem;color:var(--body);font-weight:500}
.sk::before{content:"✓";color:var(--blue);font-weight:700;flex-shrink:0}
.certs{border-top:1px solid var(--border);padding-top:26px;margin-top:26px;display:flex;flex-direction:column;gap:10px}
.cert-r{display:flex;align-items:center;gap:11px;font-size:.85rem}
.cert-ico{font-size:1.2rem;flex-shrink:0}
.cert-n{font-weight:600;color:var(--ink)}
.cert-s{font-size:.76rem;color:var(--muted);margin-top:1px}

/* SERVICES */
.services{padding:108px 0;background:var(--off)}
.svc-g{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px}
.svc{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:34px 30px;position:relative;transition:all .3s;overflow:hidden}
.svc::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--blue);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.svc:hover{box-shadow:var(--shadow-lg);transform:translateY(-4px);border-color:transparent}
.svc:hover::before{transform:scaleX(1)}
.svc-n{font-size:.68rem;font-weight:700;letter-spacing:2px;color:var(--muted);margin-bottom:16px;display:block;text-transform:uppercase}
.svc-ico{width:46px;height:46px;border-radius:8px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:16px}
.svc h3{font-family:"Libre Baskerville",serif;font-size:1.05rem;color:var(--ink);margin-bottom:9px;line-height:1.3}
.svc p{font-size:.86rem;color:var(--muted);line-height:1.68;margin-bottom:16px}
.svc ul{list-style:none;display:flex;flex-direction:column;gap:5px}
.svc ul li{font-size:.81rem;color:var(--body);display:flex;align-items:flex-start;gap:7px;line-height:1.4}
.svc ul li::before{content:"→";color:var(--blue);font-weight:700;flex-shrink:0;margin-top:1px}

/* PROCESS */
.process{padding:108px 0;background:var(--white)}
.proc-track{display:grid;grid-template-columns:repeat(4,1fr);position:relative;gap:0;margin-top:64px}
.proc-track::before{content:"";position:absolute;top:36px;left:12%;right:12%;height:1px;background:var(--border);z-index:0}
.ps{position:relative;z-index:1;text-align:center;padding:0 22px}
.ps-circle{width:72px;height:72px;border-radius:50%;background:var(--white);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;margin:0 auto 22px;font-family:"Libre Baskerville",serif;font-size:1.35rem;color:var(--blue);font-weight:700;box-shadow:var(--shadow);transition:all .3s}
.ps:hover .ps-circle{background:var(--blue);color:#fff;border-color:var(--blue);box-shadow:0 8px 24px rgba(29,78,137,.25)}
.ps h4{font-family:"Libre Baskerville",serif;font-size:.98rem;color:var(--ink);margin-bottom:8px}
.ps p{font-size:.82rem;color:var(--muted);line-height:1.6}

/* PHOTO SPLIT */
.photo-split{display:grid;grid-template-columns:1fr 1fr;min-height:480px}
.ps-img{background:url('https://images.pexels.com/photos/4481326/pexels-photo-4481326.jpeg?auto=compress&cs=tinysrgb&w=900&fit=crop') center/cover}
.ps-box{background:var(--blue);padding:80px 64px;display:flex;flex-direction:column;justify-content:center}
.ps-box .section-h{color:#fff}
.ps-box .section-sub{color:rgba(255,255,255,.68);max-width:420px}
.ps-stats{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:40px}
.pss{border-top:1px solid rgba(255,255,255,.2);padding-top:18px}
.pss-n{font-family:"Libre Baskerville",serif;font-size:2.3rem;font-weight:700;color:#fff;line-height:1;margin-bottom:5px}
.pss-l{font-size:.79rem;color:rgba(255,255,255,.58);line-height:1.4}

/* INDUSTRIES */
.industries{padding:108px 0;background:var(--off)}
.ind-g{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:56px}
.ind{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:28px 20px;text-align:center;transition:all .28s;cursor:default}
.ind:hover{border-color:var(--blue);box-shadow:var(--shadow);transform:translateY(-3px)}
.ind:hover .ind-ico{background:var(--blue);color:#fff}
.ind-ico{width:50px;height:50px;border-radius:50%;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:1.35rem;margin:0 auto 13px;transition:all .25s}
.ind-n{font-weight:600;font-size:.88rem;color:var(--ink);margin-bottom:5px}
.ind-d{font-size:.76rem;color:var(--muted);line-height:1.5}

/* TESTIMONIALS */
.testi{padding:108px 0;background:var(--white)}
.tcard-g{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px}
.tcard{background:var(--off);border:1px solid var(--border);border-radius:6px;padding:34px 28px;transition:all .28s}
.tcard:hover{border-color:rgba(29,78,137,.2);box-shadow:var(--shadow);background:var(--white)}
.tcard-stars{color:#d97706;font-size:.88rem;letter-spacing:2px;margin-bottom:14px}
.tcard-q{font-family:"Libre Baskerville",serif;font-style:italic;font-size:.95rem;color:var(--body);line-height:1.7;margin-bottom:22px}
.tcard-div{height:1px;background:var(--border);margin-bottom:18px}
.tcard-a{display:flex;align-items:center;gap:11px}
.tcard-av{width:38px;height:38px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-family:"Libre Baskerville",serif;font-size:.9rem;color:#fff;flex-shrink:0;font-weight:700}
.tcard-n{font-weight:600;font-size:.88rem;color:var(--ink)}
.tcard-r{font-size:.74rem;color:var(--muted);margin-top:2px}

/* FAQ */
.faq{padding:108px 0;background:var(--off)}
.faq-cols{display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:940px;margin-top:56px}
.fi{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden}
.fi.open{border-color:rgba(29,78,137,.3)}
.fi-btn{width:100%;background:none;border:none;padding:19px 22px;display:flex;justify-content:space-between;align-items:center;gap:12px;cursor:pointer;text-align:left}
.fi-q{font-family:"Libre Baskerville",serif;font-size:.93rem;color:var(--ink)}
.fi-ico{width:25px;height:25px;border-radius:4px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;color:var(--blue);font-size:.95rem;flex-shrink:0;transition:all .3s}
.fi.open .fi-ico{background:var(--blue);color:#fff;transform:rotate(45deg)}
